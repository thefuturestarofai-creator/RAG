# ============================================================
# RAG 系统环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# OpenAI 配置
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 端口配置
APP_PORT=8000
CHROMA_PORT=8001

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
